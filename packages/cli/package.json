{
  "name": "@min-script-launcher/cli",
  "version": "0.1.0",
  "description": "Native CLI/TUI for launching agent-generated scripts",
  "keywords": [
    "cli",
    "ink",
    "script-launcher"
  ],
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "msl": "dist/index.js",
    "min-script-launcher": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "build:native": "bun build ./src/index.ts --compile --outfile ./dist/msl",
    "prepare": "tsc -b",
    "test": "vitest run",
    "lint": "biome check --write src test",
    "lint:ci": "biome check src test",
    "format": "biome format --write src test",
    "format:check": "biome format src test"
  },
  "dependencies": {
    "@min-script-launcher/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^15.0.0",
    "ink": "^7.1.0",
    "react": "^19.2.7",
    "react-devtools-core": "^7.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "^19.2.17",
    "vitest": "latest"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cmwen/min-script-launcher.git",
    "directory": "packages/cli"
  },
  "license": "MIT"
}
