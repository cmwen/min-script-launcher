{
  "name": "@min-script-launcher/core",
  "version": "0.1.0",
  "description": "Script discovery, metadata parsing, and search",
  "keywords": [
    "scripts",
    "search",
    "metadata"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "prepare": "tsc -b",
    "test": "vitest run",
    "lint": "biome check --write src test",
    "lint:ci": "biome check src test",
    "format": "biome format --write src test",
    "format:check": "biome format src test"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "latest",
    "vitest": "latest"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cmwen/min-script-launcher.git",
    "directory": "packages/core"
  },
  "license": "MIT"
}
